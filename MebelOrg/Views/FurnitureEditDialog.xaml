<Window x:Class="MebelOrg.Views.FurnitureEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование товара"
        Icon="/Resources/icon.ico"
        Height="650" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFFFF">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="15">
        <StackPanel>
            <!-- Артикул -->
            <TextBlock Text="Артикул" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri" Margin="0,0,0,5"/>
            <TextBox x:Name="ArticleInput" FontFamily="Calibri" FontSize="13" Height="30" Padding="5"/>

            <!-- Наименование -->
            <TextBlock Text="Наименование" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri" Margin="0,10,0,5"/>
            <TextBox x:Name="NameInput" FontFamily="Calibri" FontSize="13" Height="30" Padding="5"/>

            <!-- Ед. изм. -->
            <TextBlock Text="Ед. изм." FontSize="13" FontWeight="SemiBold" FontFamily="Calibri" Margin="0,10,0,5"/>
            <TextBox x:Name="UnitInput" FontFamily="Calibri" FontSize="13" Height="30" Padding="5"/>

            <!-- Цена -->
            <TextBlock Text="Цена" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri" Margin="0,10,0,5"/>
            <TextBox x:Name="PriceInput" FontFamily="Calibri" FontSize="13" Height="30" Padding="5"/>

            <!-- Поставщик -->
            <TextBlock Text="Поставщик" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri" Margin="0,10,0,5"/>
            <TextBox x:Name="SupplierInput" FontFamily="Calibri" FontSize="13" Height="30" Padding="5"/>

            <!-- Производитель -->
            <TextBlock Text="Производитель" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri" Margin="0,10,0,5"/>
            <TextBox x:Name="ManufacturerInput" FontFamily="Calibri" FontSize="13" Height="30" Padding="5"/>

            <!-- Категория -->
            <TextBlock Text="Категория" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri" Margin="0,10,0,5"/>
            <TextBox x:Name="CategoryInput" FontFamily="Calibri" FontSize="13" Height="30" Padding="5"/>

            <!-- Скидка % с индикатором -->
            <TextBlock Text="Скидка %" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri" Margin="0,10,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBox x:Name="DiscountInput" Width="80" FontFamily="Calibri" FontSize="13" Height="30" Padding="5" 
                         TextChanged="DiscountInput_TextChanged"/>
                <TextBlock x:Name="DiscountWarning" Text="⚠️ Скидка более 15% - товар будет выделен цветом #008080" 
                           FontSize="11" Foreground="#008080" Margin="10,0,0,0" VerticalAlignment="Center"
                           Visibility="Collapsed" FontFamily="Calibri" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Количество на складе -->
            <TextBlock Text="Количество на складе" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri" Margin="0,10,0,5"/>
            <TextBox x:Name="StockInput" FontFamily="Calibri" FontSize="13" Height="30" Padding="5"/>

            <!-- Описание -->
            <TextBlock Text="Описание" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri" Margin="0,10,0,5"/>
            <TextBox x:Name="DescriptionInput" Height="80" TextWrapping="Wrap" AcceptsReturn="True" 
                     FontFamily="Calibri" FontSize="13" Padding="5" VerticalScrollBarVisibility="Auto"/>

            <!-- Файл изображения -->
            <TextBlock Text="Файл изображения" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri" Margin="0,10,0,5"/>
            <TextBox x:Name="ImageInput" FontFamily="Calibri" FontSize="13" Height="30" Padding="5"/>

            <!-- Предпросмотр изображения -->
            <Border Background="#F0F0F0" CornerRadius="5" Margin="0,10,0,0" Padding="10">
                <StackPanel>
                    <TextBlock Text="Предпросмотр изображения:" FontSize="12" FontFamily="Calibri" Foreground="#555" Margin="0,0,0,5"/>
                    <Image x:Name="PreviewImage" Width="100" Height="100" Stretch="Uniform" Margin="0,0,0,5"/>
                    <TextBlock x:Name="NoImageText" Text="Нет изображения" FontSize="11" FontFamily="Calibri" Foreground="#888" 
                               HorizontalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,10">
                <Button Content="Сохранить" Background="#0000FF" Foreground="White" 
                        FontFamily="Calibri" FontSize="13" FontWeight="Bold"
                        Padding="20,10" Margin="4" BorderThickness="0" Cursor="Hand" 
                        Click="OnSaveClick" Width="100" Height="35"/>
                <Button Content="Отмена" Background="#00FFFF" Foreground="#333333" 
                        FontFamily="Calibri" FontSize="13"
                        Padding="20,10" Margin="4" BorderThickness="0" Cursor="Hand" 
                        IsCancel="True" Width="100" Height="35"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>