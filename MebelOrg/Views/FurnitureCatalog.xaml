<UserControl x:Class="MebelOrg.Views.FurnitureCatalog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MebelOrg.Converters">

    <UserControl.Resources>
        <conv:ImageLoaderConverter x:Key="ImageSourceConverter"/>
        <conv:RowColorConverter x:Key="RowColorConverter"/>
    </UserControl.Resources>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтров -->
        <Border x:Name="FilterPanel" Grid.Row="0" Background="#00FFFF" Padding="10" Margin="0,0,0,10" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="Поиск" FontSize="13" FontWeight="SemiBold" Foreground="#333333" FontFamily="Calibri"/>
                    <TextBox x:Name="SearchBox" TextChanged="OnFilterChanged" Height="30" FontFamily="Calibri" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Категория" FontSize="13" FontWeight="SemiBold" Foreground="#333333" FontFamily="Calibri"/>
                    <ComboBox x:Name="CategoryFilter" SelectionChanged="OnFilterChanged" Height="30" FontFamily="Calibri" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="Поставщик" FontSize="13" FontWeight="SemiBold" Foreground="#333333" FontFamily="Calibri"/>
                    <ComboBox x:Name="SupplierFilter" SelectionChanged="OnFilterChanged" Height="30" FontFamily="Calibri" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="5">
                    <TextBlock Text="Сортировка" FontSize="13" FontWeight="SemiBold" Foreground="#333333" FontFamily="Calibri"/>
                    <ComboBox x:Name="SortBox" SelectionChanged="OnFilterChanged" Height="30" FontFamily="Calibri" FontSize="13"/>
                </StackPanel>
                <Button Grid.Column="4" Content="Сбросить" Background="#0000FF" Foreground="White" 
                        FontFamily="Calibri" FontSize="12" FontWeight="Bold"
                        Padding="12,6" Margin="4" BorderThickness="0" Cursor="Hand"
                        VerticalAlignment="Bottom" Click="OnResetClick" Height="30"/>
            </Grid>
        </Border>

        <!-- Таблица товаров с цветом фона для скидки > 15% -->
        <DataGrid x:Name="FurnitureGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" SelectionMode="Single" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#F5F5F5"
                  FontFamily="Calibri" FontSize="13">

            <!-- Стиль строк - фон #008080 при скидке > 15% -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#FFFFFF"/>
                    <Setter Property="Foreground" Value="#333333"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasHighDiscount}" Value="True">
                            <Setter Property="Background" Value="#008080"/>
                            <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#0000FF"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Фото" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ImageFile, Converter={StaticResource ImageSourceConverter}}"
                                   Width="50" Height="50" Stretch="Uniform" Margin="5"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="80"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="130"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="120"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:N2} ₽}" Width="100"/>
                <DataGridTextColumn Header="Скидка %" Binding="{Binding DiscountPercent}" Width="80"/>
                <DataGridTextColumn Header="Цена со скидкой" Binding="{Binding FinalPrice, StringFormat={}{0:N2} ₽}" Width="110"/>
                <DataGridTextColumn Header="На складе" Binding="{Binding QuantityInStock}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel x:Name="AdminPanel" Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Добавить" Background="#0000FF" Foreground="White" 
                    FontFamily="Calibri" FontSize="13" FontWeight="Bold"
                    Padding="16,8" Margin="4" BorderThickness="0" Cursor="Hand" Click="OnAddClick"/>
            <Button Content="Изменить" Background="#00FFFF" Foreground="#333333" 
                    FontFamily="Calibri" FontSize="13"
                    Padding="16,8" Margin="4" BorderThickness="0" Cursor="Hand" Click="OnEditClick"/>
            <Button Content="Удалить" Background="#00FFFF" Foreground="White" 
                    FontFamily="Calibri" FontSize="13"
                    Padding="16,8" Margin="4" BorderThickness="0" Cursor="Hand" Click="OnDeleteClick"/>
        </StackPanel>
    </Grid>
</UserControl>