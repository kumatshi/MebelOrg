<Window x:Class="MebelOrg.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ООО «МебельОрг» — Вход в систему"
        Icon="/Resources/icon.ico"
        Height="700" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#FFFFFF" Margin="0,0,0,-39">
        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition/>
            <RowDefinition Height="Auto" MinHeight="155.04"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#00FFFF">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="/Resources/icon.png" 
                       Height="70" Stretch="Uniform" RenderTransformOrigin="0.745,0.5"/>
                <TextBlock Text="ООО «МебельОрг»" FontSize="22" FontWeight="Bold" Foreground="#0000FF" HorizontalAlignment="Center"/>
                <TextBlock Text="Магазин качественной мебели" FontSize="13" Foreground="#333333" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="50,30,50,119">
            <TextBlock Text="Логин" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="LoginInput" Height="35" Padding="10,5" FontSize="14" FontFamily="Calibri"/>

            <TextBlock Text="Пароль" FontSize="14" FontWeight="SemiBold" Margin="0,15,0,5"/>
            <PasswordBox x:Name="PasswordInput" Height="35" Padding="10,5" FontSize="14" FontFamily="Calibri"/>

            <TextBlock x:Name="ErrorMessage" Foreground="#FF0000" TextWrapping="Wrap" 
                       Margin="0,15,0,0" Visibility="Collapsed" TextAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="50,0,50,30">
            <Button Content="ВОЙТИ" Background="#0000FF" Foreground="White" 
                    FontFamily="Calibri" FontSize="14" FontWeight="Bold"
                    Padding="20,10" BorderThickness="0" Cursor="Hand"
                    Height="40" Click="OnLoginClick"/>
            <Button Content="ПРОДОЛЖИТЬ КАК ГОСТЬ" Background="#00FFFF" Foreground="#333333" 
                    FontFamily="Calibri" FontSize="14"
                    Padding="20,10" BorderThickness="0" Cursor="Hand"
                    Height="40" Margin="0,10,0,0" Click="OnGuestClick"/>
        </StackPanel>
    </Grid>
</Window>