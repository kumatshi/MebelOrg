<Window x:Class="MebelOrg.Views.OrderEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование заказа"
        Icon="/Resources/icon.ico"
        Height="550" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15" Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Номер заказа" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri"/>
                    <TextBox x:Name="NumberInput" FontFamily="Calibri" FontSize="13" Margin="0,2,0,10"/>

                    <TextBlock Text="Дата заказа" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri"/>
                    <DatePicker x:Name="OrderDatePicker" FontFamily="Calibri" FontSize="13" Margin="0,2,0,10"/>

                    <TextBlock Text="Дата выдачи" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri"/>
                    <DatePicker x:Name="DeliveryDatePicker" FontFamily="Calibri" FontSize="13" Margin="0,2,0,10"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Пункт выдачи" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri"/>
                    <ComboBox x:Name="PickupCombo" DisplayMemberPath="Address" FontFamily="Calibri" FontSize="13" Margin="0,2,0,10"/>

                    <TextBlock Text="ФИО клиента" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri"/>
                    <TextBox x:Name="CustomerInput" FontFamily="Calibri" FontSize="13" Margin="0,2,0,10"/>

                    <TextBlock Text="Код получения" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri"/>
                    <TextBox x:Name="CodeInput" FontFamily="Calibri" FontSize="13" Margin="0,2,0,10"/>

                    <TextBlock Text="Статус" FontSize="13" FontWeight="SemiBold" FontFamily="Calibri"/>
                    <TextBox x:Name="StatusInput" FontFamily="Calibri" FontSize="13" Margin="0,2,0,10"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <GroupBox Grid.Row="1" Header="Позиции заказа" Margin="0,15,0,15" FontFamily="Calibri" FontSize="13" FontWeight="SemiBold">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <ComboBox x:Name="ProductCombo" Width="300" DisplayMemberPath="Name" FontFamily="Calibri" FontSize="13" Margin="0,0,10,0"/>
                    <TextBox x:Name="QuantityInput" Width="60" Text="1" FontFamily="Calibri" FontSize="13" Margin="0,0,10,0"/>
                    <Button Content="Добавить" Background="#0000FF" Foreground="White" 
                            FontFamily="Calibri" FontSize="12" FontWeight="Bold"
                            Padding="12,6" BorderThickness="0" Cursor="Hand" Click="OnAddItemClick"/>
                    <Button Content="Удалить" Background="#00FFFF" Foreground="White" 
                            FontFamily="Calibri" FontSize="12"
                            Padding="12,6" BorderThickness="0" Cursor="Hand" Click="OnRemoveItemClick"/>
                </StackPanel>
                <DataGrid x:Name="ItemsGrid" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="200"
                          FontFamily="Calibri" FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="100"/>
                        <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Background="#0000FF" Foreground="White" 
                    FontFamily="Calibri" FontSize="13" FontWeight="Bold"
                    Padding="16,8" Margin="4" BorderThickness="0" Cursor="Hand" Click="OnSaveClick"/>
            <Button Content="Отмена" Background="#00FFFF" Foreground="#333333" 
                    FontFamily="Calibri" FontSize="13"
                    Padding="16,8" Margin="4" BorderThickness="0" Cursor="Hand" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>