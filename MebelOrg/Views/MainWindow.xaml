<Window x:Class="MebelOrg.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MebelOrg.Views"
        Title="ООО «МебельОрг» — Главная"
        Icon="/Resources/icon.ico"
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        MinHeight="600" MinWidth="900">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#00FFFF" Height="75">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Source="/Resources/icon.png" Height="50" Stretch="Uniform"/>

                <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="ООО «МебельОрг»" FontSize="20" FontWeight="Bold" Foreground="#0000FF"/>
                    <TextBlock x:Name="UserInfoText" FontSize="12" Foreground="#333333"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ProductsNavBtn" Content="Товары" Background="#0000FF" Foreground="White" 
                            FontFamily="Calibri" FontSize="13" FontWeight="Bold"
                            Padding="16,8" Margin="4" BorderThickness="0" Cursor="Hand"
                            Click="OnProductsNavClick"/>
                    <Button x:Name="OrdersNavBtn" Content="Заказы" Background="#00FFFF" Foreground="#333333" 
                            FontFamily="Calibri" FontSize="13"
                            Padding="16,8" Margin="4" BorderThickness="0" Cursor="Hand"
                            Click="OnOrdersNavClick"/>
                    <Button x:Name="ExportExcelBtn" Content="Экспорт Excel" Background="#00FFFF" Foreground="#333333" 
                            FontFamily="Calibri" FontSize="13"
                            Padding="16,8" Margin="4" BorderThickness="0" Cursor="Hand"
                            Click="OnExportExcelClick" Visibility="Collapsed"/>
                    <Button x:Name="ImportExcelBtn" Content="Импорт Excel" Background="#0000FF" Foreground="White" 
                            FontFamily="Calibri" FontSize="13" FontWeight="Bold"
                            Padding="16,8" Margin="4" BorderThickness="0" Cursor="Hand"
                            Click="OnImportExcelClick" Visibility="Collapsed"/>
                    <Button Content="Выход" Background="#00FFFF" Foreground="#333333" 
                            FontFamily="Calibri" FontSize="13"
                            Padding="16,8" Margin="4" BorderThickness="0" Cursor="Hand"
                            Click="OnLogoutClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl x:Name="MainContent" Margin="15"/>
    </DockPanel>
</Window>